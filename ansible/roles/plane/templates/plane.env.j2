# Rendered by ansible — do not edit by hand.
# Non-secret config lives here in plain text; secrets are interpolated
# from the per-deployment vault file (see group_vars → vault_secrets_file).
# docker compose auto-loads .env from the project dir.

APP_DOMAIN={{ domain_plane }}

SECRET_KEY={{ plane.secret_key }}
LIVE_SERVER_SECRET_KEY={{ plane.live_server_secret_key }}

POSTGRES_PASSWORD={{ plane.postgres_password }}
RABBITMQ_PASSWORD={{ plane.rabbitmq_password }}

AWS_ACCESS_KEY_ID={{ plane.minio_access_key }}
AWS_SECRET_ACCESS_KEY={{ plane.minio_secret_key }}
