# Per-host configuration for the `plane` inventory entry.
# Copy this file to host_vars/plane.yml (gitignored) and fill in.
# Only `domain_plane` is mandatory; everything else has sensible defaults.

# Public FQDN that resolves to this host's IPv4. Required.
# Used for: Caddy site block, Plane WEB_URL/CORS_ALLOWED_ORIGINS.
#
# Pre-conditions on the host (apt-based: Debian / Ubuntu / Raspberry
# Pi OS): docker engine + compose plugin, the external `web` docker
# network, apt-installed Caddy. The play's pre_tasks probe each one
# and install/create it when missing, so the only hard requirement
# you bring is sudo SSH access to the target. On a fresh apt-Caddy
# the site block defaults to `tls internal` (self-signed cert) and
# also serves plain HTTP — works out of the box, no further config.
# Override `plane_caddy_tls_strategy` (acme/tls_files/internal) and
# `plane_caddy_offer_http` (true/false) when you want different
# behaviour. Front Plane with a different reverse proxy →
# `--skip-tags caddy`; Plane stays reachable at 127.0.0.1:8081 via
# plane_proxy_host_port.
domain_plane: plane.example.com

# The Plane Instance Admin + Workspace Owner. The plane_admin role
# creates this User, marks the instance set up, mints a bootstrap
# workspace API token (label "ansible-bootstrap"), and writes that token
# back into the vault as `plane.admin_token`. The login password is
# generated by plane_secrets and stored in the vault as
# `plane.admin_password` — view it after a run with:
#
#     ansible-vault view ansible/vault/secrets.yml | grep admin_password
plane_admin:
  email: admin@example.com
  full_name: "Plane Admin"

# Workspace the framework's agents are invited into. `slug` is the URL
# fragment Plane uses (lowercase, hyphenated, immutable once created);
# `name` is the human-readable label.
plane_workspace:
  slug: framework
  name: Framework
  owner_email: "{{ plane_admin.email }}"

# Projects to provision in the workspace. `identifier` is the short
# prefix Plane embeds in work-item IDs (e.g. FW-1).
#
# Per-project optional fields:
#   members:  list of agent usernames to restrict the project to. Omit
#             to invite everyone in `agents` (group_vars/plane_hosts.yml).
#   modules:  list of phase-module names. Omit to inherit
#             plane_bootstrap_modules (frontend/backend/testing/
#             documentation). Use `modules: []` for projects that don't
#             decompose into those phases (e.g. a strategy/founder
#             track). Module removal is not auto-reconciled — drop a
#             module from the list and the existing row stays put.
#   labels:   product-area taxonomy on parent Stories. Pick one of the
#             two framework-shipped sets:
#               labels: "{{ plane_bootstrap_labels_dev }}"
#               labels: "{{ plane_bootstrap_labels_business }}"
#             or pass an inline [{name,color}, ...] list. Omit to
#             inherit the dev set. Label removal is not auto-reconciled
#             — drop a label and the existing row stays put. Switching
#             a populated project to a different set requires deleting
#             the obsolete labels in Plane's UI first.
#
# The framework's reference setup uses a Business + Development split;
# copy/adapt as needed.
plane_projects:
  - name: Framework
    identifier: FW
    description: "Bootstrap project for the agent framework"
    # modules: []
    # labels: "{{ plane_bootstrap_labels_dev }}"
    # members:
    #   - business-analyst
    #   - software-architect

# Email domain for the 10 framework agents. Each persona's email is
# constructed as `<persona-username>@<plane_agent_email_domain>`. Use a
# domain you control (or a +alias on your own); SMTP is optional for the
# framework, so the addresses don't need to receive mail.
plane_agent_email_domain: example.com

