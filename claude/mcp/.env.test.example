# Integration-test configuration for plane-extras-mcp.
# Copy this file to .env.test and fill in real values; .env.test is
# gitignored.


# --- connection (public REST: comments, work-item lookup) ---
PLANE_VERIFY_SSL=true
PLANE_BASE_URL=https://your-plane-host.example
PLANE_WORKSPACE_SLUG=your-workspace-slug
PLANE_API_KEY=your-personal-access-token

# --- UI credentials (internal app API: pages) ---
# Required for the page tools because Plane v1.3.0 does not expose pages
# on the public REST surface. The MCP server signs in via /auth/sign-in/
# (form-encoded) and uses the resulting session cookie. These creds are
# more sensitive than a PAT — they grant full account access.
PLANE_UI_USERNAME=your-plane-account-email
PLANE_UI_PASSWORD=your-plane-account-password

# --- pre-existing test resources ---
# Recommendation: dedicate a Plane project named "MCP-Tests" for this —
# integration tests create and delete artifacts there.
PLANE_TEST_PROJECT_ID=00000000-0000-0000-0000-000000000000
# Either the work item's UUID, or the human-readable identifier shown in
# the Plane UI (e.g. "INT-1"). The MCP server resolves either form.
PLANE_TEST_ISSUE_ID=INT-1

# --- TLS for self-signed / private-CA deployments (optional) ---
# Either point to a CA bundle (preferred):
# PLANE_CA_BUNDLE=/path/to/ca-bundle.pem
# Or disable verification entirely (quick-and-dirty):
# PLANE_VERIFY_SSL=false
