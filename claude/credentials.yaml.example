# Secrets template for the Trail framework.
# Copy this file to `credentials.yaml` and fill in real values.
# `credentials.yaml` is gitignored; only this `.example` stub is safe to commit.
#
# Plane API tokens are per-agent, workspace-scoped and (typically) non-expiring.
# Two ways to fill in the values below:
#
#   1. Auto-populated from the Ansible turn-key install. The `plane_users`
#      role mints all ten tokens during the provisioning run and writes
#      them to `ansible/out/plane-agent-tokens-plane.yml` on the
#      controller. Copy the values into the matching keys below — same
#      `plane_api_<hex>` format.
#
#   2. Manually, from the Plane UI. For each agent, sign in as that user
#      and visit Workspace Settings → API tokens → Add token (give it a
#      label like `claude-code`). Paste the resulting token below.
#
# Rotate by deleting the token in Plane UI (or `ansible-playbook plane.yml
# --tags plane_users` after deleting the APIToken row) and re-issuing.

plane:
  agent-tokens:
    venture-advisor:       # plane_api_...
    business-analyst:      # plane_api_...
    requirements-engineer: # plane_api_...
    software-architect:    # plane_api_...
    security-reviewer:     # plane_api_...
    backend-developer:     # plane_api_...
    ui-developer:          # plane_api_...
    test-manager:          # plane_api_...
    technical-writer:      # plane_api_...
    release-manager:       # plane_api_...
